<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="website_video_upload.UploadVideoSelector">
        <div class="row mt-3 px-3">
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label fw-bold">Upload a video file</label>
                    <input type="file" class="form-control"
                           accept="video/mp4,video/webm,video/ogg"
                           t-on-change="onFileChange"/>
                    <div class="form-text">Accepts MP4, WebM, and OGG files</div>
                </div>
                <t t-if="state.uploading">
                    <div class="text-center py-3">
                        <i class="fa fa-spinner fa-spin fa-2x"/>
                        <p class="mt-2 text-muted">Uploading...</p>
                    </div>
                </t>
                <t t-if="state.videoUrl and !state.uploading">
                    <div class="mb-3">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox"
                                   id="vu_autoplay"
                                   t-att-checked="state.autoplay"
                                   t-on-change="onToggleAutoplay"/>
                            <label class="form-check-label" for="vu_autoplay">Autoplay</label>
                        </div>
                        <div class="text-muted small mb-2" t-if="state.autoplay">
                            Videos are muted when autoplay is enabled
                        </div>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox"
                                   id="vu_loop"
                                   t-att-checked="state.loop"
                                   t-on-change="onToggleLoop"/>
                            <label class="form-check-label" for="vu_loop">Loop</label>
                        </div>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox"
                                   id="vu_controls"
                                   t-att-checked="state.controls"
                                   t-on-change="onToggleControls"/>
                            <label class="form-check-label" for="vu_controls">Show player controls</label>
                        </div>
                    </div>
                </t>
            </div>
            <div class="col-md-6">
                <t t-if="state.videoUrl">
                    <video t-att-src="state.videoUrl"
                           controls=""
                           playsinline=""
                           style="width:100%;max-width:100%;border-radius:8px;"/>
                </t>
                <t t-else="">
                    <div class="d-flex align-items-center justify-content-center bg-light rounded"
                         style="min-height: 200px;">
                        <div class="text-center text-muted">
                            <i class="fa fa-film fa-3x mb-2 d-block"/>
                            <span>Video preview</span>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>

</templates>
